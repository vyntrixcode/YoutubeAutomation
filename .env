# === ElevenLabs TTS ===
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# === Gmail OAuth (for all services) ===

#Optional If you want automatic login or you can use python login.py to login once and save cockies and sessions for later use.
GMAIL_EMAIL=
GMAIL_PASSWORD=

# === Configuration ===
# Max retries for failed image generation
MAX_RETRIES=3

# Headless browser mode (true/false)
HEADLESS=false

# === Segmentation ===
# Default words per audio segment (if not specified interactively)
# ~150 words = ~1 minute at normal speaking pace
WORDS_PER_SEGMENT=150
